APP_NAME=Laravel
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=sqlite
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=laravel
# DB_USERNAME=root
# DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"

# Voice Telekom SMS (OTP) — Randevumcepte ile aynı sağlayıcı
VOICETELEKOM_ENABLED=false
VOICETELEKOM_HOST=smsvt.voicetelekom.com
VOICETELEKOM_PORT=9587
VOICETELEKOM_USERNAME=
VOICETELEKOM_PASSWORD=
VOICETELEKOM_SENDER=FEROGO
VOICETELEKOM_VALIDITY=60
VOICETELEKOM_COMMERCIAL=false

# ─── WebRTC sesli görüşme (yolcu ↔ sürücü) ────────────────────
# STUN yeterli DEĞİL: Türk mobil operatörleri simetrik NAT/CGNAT arkasında,
# P2P kurulamaz → ses gelmez. Production'da TURN ŞART.
# coturn kurulumu: docs/COTURN_VOICE_SETUP.md
STUN_URLS=stun:stun.l.google.com:19302,stun:stun1.l.google.com:19302
# voice.ferxgo.com üstündeki coturn — kurulumdan sonra doldur:
TURN_URLS=
TURN_USERNAME=
TURN_CREDENTIAL=

# ─── Mobil API ────────────────────────────────────────────────
# Sanctum mobile token TTL (dakika) — config/sanctum.php okur (default 30 gün)
# Stateful domain'ler boş bırakılabilir — web tarafı session-cookie, mobile bearer kullanıyor
SANCTUM_STATEFUL_DOMAINS=

# Firebase Cloud Messaging (push bildirim) — server key veya HTTP v1 service account
# https://console.firebase.google.com → Project Settings → Cloud Messaging
FCM_HTTP_V1_ENABLED=false
FCM_PROJECT_ID=
# Service account JSON path (storage/app/firebase-service-account.json önerilir)
FCM_CREDENTIALS_PATH=storage/app/firebase-service-account.json

# ─── PayTR — Sürücü paket ödemeleri (iframe API) ──────────────
# enabled=false iken MockGateway devrede (fake checkout, gerçek tahsilat yok).
# test_mode=true → PayTR test kartları ile çalışır, gerçek para çekilmez.
# Bildirim URL'i PayTR mağaza panelinde tanımlanmalı:
#   https://appnew.randevumcepte.com.tr/api/paytr/bildirim
# Üretimde Ferxgo'ya özel mağaza credential'ları ile değiştir + test_mode=false.
PAYTR_ENABLED=false
PAYTR_MERCHANT_ID=
PAYTR_MERCHANT_KEY=
PAYTR_MERCHANT_SALT=
PAYTR_TEST_MODE=true
PAYTR_TIMEOUT_LIMIT=30
PAYTR_MAX_INSTALLMENT=1

# Geçici: PayTR canlı bildirim akışı doğrulanırken 1₺ paketi göster.
# Doğrulama bitince false yap veya bu satırı sil.
SHOW_TEST_PACKAGE=false

# TEST / QA MODU
# false yapmak = sürücü PAKET olmadan da müsait olabilir, radar'a düşer,
# iş kabul eder. Test/QA sırasında ödeme akışı devre dışı bırakmak için.
# Prod'da MUTLAKA true. Tüm testler bittikten sonra bu satırı kaldır veya
# true yap.
DRIVER_ENFORCE_PACKAGES=true
